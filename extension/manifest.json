{
  "manifest_version": 3,
  "name": "LakeStream Scraper",
  "version": "1.1.0",
  "description": "Extract structured data from any website — tables, lists, card grids. Smart extractors for LinkedIn Sales Nav & Apollo.",
  "permissions": ["storage", "activeTab", "downloads", "cookies"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.linkedin.com/*",
    "https://www.apollo.io/*",
    "https://app.apollo.io/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/sales/*"],
      "js": ["content/linkedin-sales-nav.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.apollo.io/*"],
      "js": ["content/apollo.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/auto-detect.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
