# Server
PORT=3001
HOST=0.0.0.0
DEBUG=false
LOG_LEVEL=info

# Database (Postgres)
DATABASE_URL=postgresql://scraper:scraper_dev@localhost:5433/lakeb2b_scraper

# Redis (for arq job queue)
REDIS_URL=redis://localhost:6381

# Authentication (REQUIRED)
# Generate JWT_SECRET with: openssl rand -hex 32
JWT_SECRET=your-secret-key-here-use-openssl-rand-hex-32

# Admin credentials (seeded on first boot, updated on every restart)
ADMIN_EMAIL=admin@lakeb2b.internal
ADMIN_PASSWORD=LakeB2B_admin!

# Proxy services
BRIGHTDATA_PROXY_URL=
SMARTPROXY_URL=
CUSTOM_PROXY_URL=
CUSTOM_PROXY_USERNAME=
CUSTOM_PROXY_PASSWORD=

# Playwright session-based scraping
PLAYWRIGHT_SESSION_TTL_SECONDS=3600
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000
LINKEDIN_SESSION_COOKIES=

# LakeCurrent search API
LAKECURRENT_BASE_URL=http://lakecurrent-backend:8001
LAKECURRENT_TIMEOUT=15.0
LAKECURRENT_ENABLED=false

# Limits (Unlimited Scraping Mode)
MAX_CONCURRENT_JOBS=10
MAX_SCRAPE_PAGES_PER_JOB=  # Empty for unlimited scraping
DEFAULT_RATE_LIMIT_MS=0  # 0 = no rate limiting

# Email notifications (ChampMail mail engine)
MAIL_ENGINE_URL=http://localhost:8025
MAIL_ENGINE_API_KEY=
MAIL_ENGINE_FROM_ADDRESS=LakeStream <notifications@lakeb2b.com>
MAIL_ENGINE_ENABLED=false
